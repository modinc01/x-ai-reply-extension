{
    "manifest_version": 3,
    "name": "X AI Reply Generator",
    "version": "0.0.1",
    "description": "X(Twitter)のポストに対してClaude AIでリプライを自動生成するChrome拡張機能",
    "icons": {
          "16": "icons/icon16.png",
          "48": "icons/icon48.png",
          "128": "icons/icon128.png"
    },
    "permissions": ["storage"],
    "host_permissions": [
          "https://x.com/*",
          "https://api.anthropic.com/*"
    ],
    "content_scripts": [
          {
                  "matches": ["https://x.com/*", "https://twitter.com/*"],
                  "js": ["content.js"],
                  "css": ["styles.css"],
                  "run_at": "document_idle"
          }
    ],
    "action": {
          "default_popup": "popup.html",
          "default_icon": {
                  "16": "icons/icon16.png",
                  "48": "icons/icon48.png",
                  "128": "icons/icon128.png"
          },
          "default_title": "X AI Reply 設定"
    }
}
